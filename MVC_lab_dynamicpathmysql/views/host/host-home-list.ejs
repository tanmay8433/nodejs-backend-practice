<%- include('../partials/head') %>
</head>

<body class="bg-gray-100">

    <header>
        <%- include('../partials/header') %>
    </header>

    <main class="max-w-7xl mx-auto mt-10 p-8">

        <h2 class="text-3xl font-bold text-gray-700 text-center mb-10">
            Here are our host homes list:
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">

            <% registerHomes.forEach(home => { %>

                <!-- Card -->
                <div class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-2xl hover:-translate-y-2 transition duration-300">

                    <!-- Image -->
                    <div class="h-56 overflow-hidden">
                        <img 
                            src="<%= home.imagrUrl %>" 
                            alt="<%= home.name %>"
                            class="w-full h-full object-cover hover:scale-110 transition duration-500"
                        >
                    </div>

                    <!-- Card Content -->
                    <div class="p-5">

                        <h3 class="text-2xl font-bold text-gray-800 mb-2">
                            <%= home.houseName %>
                        </h3>

                        <p class="text-gray-500 mb-3">
                            📍 <%= home.location %>
                        </p>

                        <div class="flex justify-between items-center mb-5">

                            <p class="text-lg font-semibold text-blue-600">
                                ₹<%= home.price %>/night
                            </p>

                            <span class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-sm font-medium">
                                ⭐ <%= home.rating %>
                            </span>
 <p class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded-md text-sm">
                        ⭐ <%= home.description %>
                    </p>
                        </div>

                        <!-- Buttons -->
                        <div class="flex gap-3">

                            <a href="/host/edit-home/<%=home.id%>?editing=true" class="w-full bg-green-500 hover:bg-green-600 text-white py-2 rounded-lg font-medium transition"
                            >
                                Edit
                            </a>
<form action="/host/delete-home/<%= home.id %>" method="POST"> 

    <button class="w-full bg-red-500 hover:bg-red-600 text-white py-2 rounded-lg font-medium transition">
        Delete
    </button>
</form>

                        </div>

                    </div>

                </div>

            <% }) %>

        </div>

    </main>

</body>
</html>