   <%- include('../partials/head') %>
</head>
<body>
  <header>
     <%- include('../partials/header') %>
 <main class="max-w-xl mx-auto mt-10 bg-white shadow-lg rounded-lg p-8">

    <h2 class="text-2xl font-bold text-gray-500 text-center mb-6">
        welcome to Airbnb index page:
    </h2>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% registerHomes.forEach(home => { %>

        <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-2xl transition duration-300">

            <img 
                src="<%= home.imagrUrl %>" 
                alt="<%= home.houseName %>"
                class="w-full h-48 object-cover"
            >

            <div class="p-5">

                <h3 class="text-xl font-bold text-gray-800 mb-2">
                    <%= home.name %>
                </h3>

                <p class="text-gray-600 mb-2">
                    📍 <%= home.location %>
                </p>

                <div class="flex justify-between items-center mb-4">

                    <p class="text-blue-600 font-semibold">
                        ₹<%= home.price %>/night
                    </p>

                    <p class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded-md text-sm">
                        ⭐ <%= home.rating %>
                    </p>
                </br>
 <p class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded-md text-sm">
                        ⭐ <%= home.description %>
                    </p>
                </div>

<button class="bg-green-500 p-2">book</button>
            </div>

        </div>

    <% }) %>
</div>
</main>
</body>
</html>