   <%- include('../partials/head') %>
</head>
<body>
  <header>
     <%- include('../partials/header') %>
    

 <main class="max-w-5xl mx-auto mt-10">

    <h2 class="text-2xl font-bold text-gray-500 text-center mb-6">
        Here are our home details:
    </h2>

    <div class="flex bg-white rounded-xl shadow-lg overflow-hidden">

        <!-- Left side image -->
        <div class="w-1/2">
            <img 
                src="<%= home.photoURl %>" 
                alt="<%= home.houseName %>"
                class="w-full h-80 object-cover"
            >
        </div>

        <!-- Right side details -->
        <div class="w-1/2 p-6">

            <h3 class="text-2xl font-bold text-gray-800 mb-3">
                <%= home.houseName %>
            </h3>

            <p class="text-gray-600 mb-4">
                📍 <%= home.location %>
            </p>

            <div class="flex justify-between items-center mb-5">

                <p class="text-blue-600 font-bold text-lg">
                    ₹<%= home.price %>/night
                </p>

                <p class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-md">
                    ⭐ <%= home.rating %>
                </p>

            </div>
<%- include('../partials/favourite') %>

        </div>

    </div>

</main>
</body>
</html>