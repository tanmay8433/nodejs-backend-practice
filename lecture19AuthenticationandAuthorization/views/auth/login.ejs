<%- include('../partials/head') %>
</head>
<body class="bg-gray-100">
<header class="text-center py-6">
  <%- include('../partials/header') %>
  <p class="text-3xl font-bold mt-4">Login</p>
</header>

<main class="flex justify-center items-center min-h-[70vh]">
  <form
    action="/login"
    method="POST"
    class="bg-white p-8 rounded-xl shadow-lg w-full max-w-md"
  >
  <%- include('../partials/errors') %>
    <input
      type="email"
      name="email"
      placeholder="Enter your Email"
       value="<%= typeof oldInput !=='undefined' ? oldInput.email:'' %>"
      required
      class="w-full px-4 py-3 mb-4 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
      required
    />

    <input
      type="password"
      name="password"
      placeholder="Enter your password"
      required
      class="w-full px-4 py-3 mb-4 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
      required
    />

    <input
      type="submit"
      value="Sign In"
      class="w-full bg-blue-600 text-white py-3 rounded-lg font-semibold cursor-pointer hover:bg-blue-700 transition duration-300"
    />
  </form>
</main>
</body>
</html>